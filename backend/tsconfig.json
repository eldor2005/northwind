{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "skripLibcheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "declaration": true,
        "noUnusedLocals": true,
        "noUnusedParmeters": true
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}